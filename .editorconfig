root = true

[*.cs]
# ──────────────────────────────────────────────────────────────────────────────
# Nullable reference types — tous les codes de la doc MS en warning.
# Combiné avec TreatWarningsAsErrors=true dans Directory.Build.props,
# toute violation nullable échoue le build.
# Référence : https://learn.microsoft.com/dotnet/csharp/language-reference/compiler-messages/nullable-warnings
# ──────────────────────────────────────────────────────────────────────────────

# Valeur nulle assignée à un type non-nullable
dotnet_diagnostic.CS8597.severity = warning # Thrown value may be null
dotnet_diagnostic.CS8600.severity = warning # Converting null literal or possible null value to non-nullable type
dotnet_diagnostic.CS8601.severity = warning # Possible null reference assignment
dotnet_diagnostic.CS8603.severity = warning # Possible null reference return
dotnet_diagnostic.CS8604.severity = warning # Possible null reference argument for parameter
dotnet_diagnostic.CS8605.severity = warning # Unboxing a possibly null value
dotnet_diagnostic.CS8625.severity = warning # Cannot convert null literal to non-nullable reference type
dotnet_diagnostic.CS8629.severity = warning # Nullable value type may be null

# Déréférencement d'une valeur potentiellement nulle
dotnet_diagnostic.CS8602.severity = warning # Dereference of a possibly null reference
dotnet_diagnostic.CS8607.severity = warning # A possible null value may not be used for a type marked with [NotNull] or [DisallowNull]

# Membre non-nullable non initialisé
dotnet_diagnostic.CS8618.severity = warning # Non-nullable field/property must contain a non-null value when exiting constructor
dotnet_diagnostic.CS8762.severity = warning # Parameter must have a non-null value when exiting
dotnet_diagnostic.CS8774.severity = warning # Member must have a non-null value when exiting
dotnet_diagnostic.CS8775.severity = warning # Member must have a non-null value when exiting
dotnet_diagnostic.CS8776.severity = warning # Member cannot be used in this attribute
dotnet_diagnostic.CS8777.severity = warning # Parameter must have a non-null value when exiting

# Incohérence de nullabilité (override / interface / délégué / générique)
dotnet_diagnostic.CS8608.severity = warning # Nullability in type doesn't match overridden member
dotnet_diagnostic.CS8609.severity = warning # Nullability in return type doesn't match overridden member
dotnet_diagnostic.CS8610.severity = warning # Nullability in type of parameter doesn't match overridden member
dotnet_diagnostic.CS8611.severity = warning # Nullability in type of parameter doesn't match partial method declaration
dotnet_diagnostic.CS8612.severity = warning # Nullability in type doesn't match implicitly implemented member
dotnet_diagnostic.CS8613.severity = warning # Nullability in return type doesn't match implicitly implemented member
dotnet_diagnostic.CS8614.severity = warning # Nullability in type of parameter doesn't match implicitly implemented member
dotnet_diagnostic.CS8615.severity = warning # Nullability in type doesn't match implemented member
dotnet_diagnostic.CS8616.severity = warning # Nullability in return type doesn't match implemented member
dotnet_diagnostic.CS8617.severity = warning # Nullability in type of parameter doesn't match implemented member
dotnet_diagnostic.CS8619.severity = warning # Nullability in value doesn't match target type
dotnet_diagnostic.CS8620.severity = warning # Argument cannot be used for parameter due to nullability differences
dotnet_diagnostic.CS8621.severity = warning # Nullability in return type doesn't match the target delegate
dotnet_diagnostic.CS8622.severity = warning # Nullability in type of parameter doesn't match the target delegate
dotnet_diagnostic.CS8624.severity = warning # Argument cannot be used as an output due to nullability differences
dotnet_diagnostic.CS8631.severity = warning # Type cannot be used as type parameter — nullability mismatch constraint
dotnet_diagnostic.CS8633.severity = warning # Nullability in constraints for type parameter
dotnet_diagnostic.CS8634.severity = warning # Type cannot be used as type parameter — 'class' constraint
dotnet_diagnostic.CS8643.severity = warning # Nullability in explicit interface specifier doesn't match interface
dotnet_diagnostic.CS8644.severity = warning # Type does not implement interface member (nullability mismatch in base)
dotnet_diagnostic.CS8645.severity = warning # Member already listed in interface list with different nullability
dotnet_diagnostic.CS8667.severity = warning # Partial method declarations have inconsistent nullability in constraints
dotnet_diagnostic.CS8714.severity = warning # Type cannot be used as type parameter — 'notnull' constraint
dotnet_diagnostic.CS8764.severity = warning # Nullability of return type doesn't match overridden member
dotnet_diagnostic.CS8765.severity = warning # Nullability of type of parameter doesn't match overridden member
dotnet_diagnostic.CS8766.severity = warning # Nullability in return type doesn't match implicitly implemented member
dotnet_diagnostic.CS8767.severity = warning # Nullability in type of parameter doesn't match implicitly implemented member
dotnet_diagnostic.CS8768.severity = warning # Nullability in return type doesn't match implemented member
dotnet_diagnostic.CS8769.severity = warning # Nullability in type of parameter doesn't match implemented member
dotnet_diagnostic.CS8819.severity = warning # Nullability in return type doesn't match partial method declaration

# Attributs nullable ([DoesNotReturn], [NotNullWhen], etc.)
dotnet_diagnostic.CS8763.severity = warning # A method marked [DoesNotReturn] should not return
dotnet_diagnostic.CS8770.severity = warning # Method lacks [DoesNotReturn] annotation to match implemented member
dotnet_diagnostic.CS8824.severity = warning # Parameter must have a non-null value when exiting because it is non-null
dotnet_diagnostic.CS8825.severity = warning # Return value must be non-null because parameter is non-null

# Switch expression non-exhaustif sur null
dotnet_diagnostic.CS8655.severity = warning # Switch expression does not handle some null inputs
dotnet_diagnostic.CS8847.severity = warning # Switch expression does not handle some null inputs (when clause)

# IDE warnings
dotnet_diagnostic.IDE0290.severity = warning # Use primary constructor
dotnet_diagnostic.IDE0305.severity = warning # Simplify collection initialization

# ──────────────────────────────────────────────────────────────────────────────
# Corps de méthode/constructeur toujours en bloc { }, jamais en expression body =>.
# Combiné avec EnforceCodeStyleInBuild dans Directory.Build.props,
# toute violation échoue le build (les autres membres — propriétés, opérateurs,
# lambdas, etc. — ne sont pas encore couverts, à évaluer plus tard).
# Référence : https://learn.microsoft.com/dotnet/fundamentals/code-analysis/style-rules/ide0022
# ──────────────────────────────────────────────────────────────────────────────

csharp_style_expression_bodied_methods = false
dotnet_diagnostic.IDE0022.severity = error # Use expression body for methods

csharp_style_expression_bodied_constructors = false
dotnet_diagnostic.IDE0021.severity = error # Use expression body for constructors

# ──────────────────────────────────────────────────────────────────────────────
# AssemblyMarker : classe volontairement vide (utilisée uniquement pour
# typeof(AssemblyMarker).Assembly dans les tests d'architecture), pas un defect.
# Suppression ciblée pour ne pas désactiver S2094 ailleurs dans le code.
# ──────────────────────────────────────────────────────────────────────────────




[**/AssemblyMarker.cs]
dotnet_diagnostic.S2094.severity = none # Remove this empty class, write its code or make it an "interface"
